{
  "name": "pi-agent-workflow",
  "version": "0.1.0",
  "description": "Cost-aware, evidence-first delegation for Pi: one orchestrator, automatically routed workers, reliable execution.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xCUB3/pi-agent-workflow.git"
  },
  "homepage": "https://github.com/0xCUB3/pi-agent-workflow",
  "bugs": {
    "url": "https://github.com/0xCUB3/pi-agent-workflow/issues"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "NOTICE",
    "benchmarks",
    "CHANGELOG.md"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "delegation",
    "agents",
    "orchestration",
    "cost-aware"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "typebox": "^1.3.6",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.80.0",
    "@earendil-works/pi-tui": ">=0.80.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typebox": "*",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "check": "npm run typecheck && npm test",
    "benchmark:static": "node --import tsx benchmark/route-benchmark.ts"
  }
}
